{
  "name": "eslint-config-acme",
  "version": "4.0.0",
  "description": "ESLint + Prettier config for React",
  "keywords": [
    "eslint",
    "eslintconfig",
    "config",
    "javascript",
    "prettier"
  ],
  "homepage": "https://github.com/mryechkin/eslint-config-acme#readme",
  "bugs": {
    "url": "https://github.com/mryechkin/eslint-config-acme/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mryechkin/eslint-config-acme.git"
  },
  "license": "MIT",
  "author": {
    "name": "Mykhaylo Ryechkin",
    "url": "https://github.com/mryechkin"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./prettier": "./prettier.config.js",
    "./base": "./src/configs/base.js",
    "./typescript": "./src/configs/typescript.js"
  },
  "main": "src/index.js",
  "files": [
    "LICENSE",
    "CHANGELOG.md",
    "README.md",
    "prettier.config.js",
    "src"
  ],
  "scripts": {
    "lint": "eslint src && prettier --check .",
    "lint:fix": "eslint src --fix && prettier --write .",
    "prepare": "husky"
  },
  "overrides": {
    "eslint-import-resolver-typescript": {
      "eslint": "^10"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "^10"
    },
    "eslint-plugin-react": {
      "eslint": "^10"
    },
    "eslint-plugin-react-hooks": {
      "eslint": "^10"
    },
    "typescript-eslint": {
      "eslint": "^10"
    }
  },
  "dependencies": {
    "confusing-browser-globals": "^1.0.11",
    "globals": "^17.4.0"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2"
  },
  "peerDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9 || ^10",
    "@ianvs/prettier-plugin-sort-imports": "^4.4",
    "@stylistic/eslint-plugin": "^5.6",
    "eslint": "^9 || ^10",
    "eslint-config-prettier": "^10",
    "eslint-import-resolver-typescript": "^4",
    "eslint-plugin-import-x": "^4",
    "eslint-plugin-jsx-a11y": "^6.10",
    "eslint-plugin-react": "^7.37",
    "eslint-plugin-react-hooks": "^7.0",
    "eslint-plugin-sort-destructure-keys": "^3",
    "prettier": "^3",
    "prettier-plugin-packagejson": "^3",
    "prettier-plugin-tailwindcss": "^0.7",
    "typescript-eslint": "^8"
  },
  "peerDependenciesMeta": {
    "typescript-eslint": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
